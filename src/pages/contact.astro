---
import Layout from "../layouts/Layout.astro";

// Replace with actual Formspree form ID from formspree.io
const FORMSPREE_ID = "YOUR_FORMSPREE_ID";
---

<Layout title="Contact — Inscape Interiors">
  <section class="w-full py-12 md:py-section">
    <div class="flex flex-col md:flex-row gap-16 items-start">
      <!-- Left: Image -->
      <div class="hidden md:block w-full md:w-[45%] fade-in-element opacity-0">
        <img
          src="/images/interiors-side.jpg"
          alt="Inscape Interiors"
          class="w-full h-auto"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- Right: Contact details + Form -->
      <div class="w-full md:w-[55%] flex flex-col justify-start">
        <h1
          class="text-[48px] md:text-[56px] font-normal font-serif text-hyperlink leading-tight mb-10 fade-in-element opacity-0"
        >
          Contact
        </h1>

        <!-- Contact Details -->
        <div class="space-y-2 mb-12 fade-in-element opacity-0">
          <p class="text-lg font-light text-hyperlink">Inscape Interiors</p>
          <p class="text-lg font-light text-hyperlink">
            3rd Floor, Road No. 2, beside Talwar Hyundai,
          </p>
          <p class="text-lg font-light text-hyperlink">
            Park View Enclave, Banjara Hills,
          </p>
          <p class="text-lg font-light text-hyperlink">
            Hyderabad, Telangana 500034
          </p>
          <p class="text-lg font-light text-hyperlink mt-4">
            <a
              href="mailto:dezinekraft.studio@gmail.com"
              class="hover:opacity-60 transition-opacity duration-300"
            >
              dezinekraft.studio@gmail.com
            </a>
          </p>
          <p class="text-lg font-light text-hyperlink">
            <a
              href="tel:+918885555548"
              class="hover:opacity-60 transition-opacity duration-300"
            >
              +91 88855 55548
            </a>
          </p>
        </div>

        <!-- Form -->
        <form
          action={`https://formspree.io/f/${FORMSPREE_ID}`}
          method="POST"
          class="space-y-8 fade-in-element opacity-0"
        >
          <!-- Name -->
          <div>
            <label
              for="name"
              class="text-[11px] uppercase tracking-widest text-hyperlink block mb-2"
              >Name</label
            >
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-transparent border-b border-hyperlink/30 pb-2 text-base text-hyperlink focus:outline-none focus:border-hyperlink transition-colors placeholder:text-hyperlink/40"
              placeholder="Your name"
            />
          </div>

          <!-- Email -->
          <div>
            <label
              for="email"
              class="text-[11px] uppercase tracking-widest text-hyperlink block mb-2"
              >Email</label
            >
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-transparent border-b border-hyperlink/30 pb-2 text-base text-hyperlink focus:outline-none focus:border-hyperlink transition-colors placeholder:text-hyperlink/40"
              placeholder="Your email"
            />
          </div>

          <!-- Phone -->
          <div>
            <label
              for="phone"
              class="text-[11px] uppercase tracking-widest text-hyperlink block mb-2"
              >Phone</label
            >
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full bg-transparent border-b border-hyperlink/30 pb-2 text-base text-hyperlink focus:outline-none focus:border-hyperlink transition-colors placeholder:text-hyperlink/40"
              placeholder="Your phone number"
            />
          </div>

          <!-- Enquiry -->
          <div>
            <label
              for="enquiry"
              class="text-[11px] uppercase tracking-widest text-hyperlink block mb-2"
              >Enquiry</label
            >
            <textarea
              id="enquiry"
              name="enquiry"
              rows="5"
              required
              class="w-full bg-transparent border-b border-hyperlink/30 pb-2 text-base text-hyperlink focus:outline-none focus:border-hyperlink transition-colors resize-none placeholder:text-hyperlink/40"
              placeholder="Tell us about your project..."></textarea>
          </div>

          <!-- Submit -->
          <div class="pt-2">
            <button
              type="submit"
              class="inline-block px-8 py-3 bg-secondary text-primary rounded-full border border-secondary hover:bg-primary hover:text-secondary transition-colors duration-300 text-base"
            >
              Send Enquiry
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .fade-in-element {
    transition:
      opacity 1.2s ease-out,
      transform 1.2s ease-out;
    transform: translateY(20px);
  }

  .fade-in-element.visible {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add("visible");
          }, index * 200);
        }
      });
    },
    { threshold: 0.15 },
  );

  document.querySelectorAll(".fade-in-element").forEach((el) => {
    observer.observe(el);
  });
</script>
