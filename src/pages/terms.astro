---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Terms & Conditions — Inscape Interiors">
  <section class="w-full py-12 md:py-section">
    <h1
      class="text-[42px] md:text-[56px] font-normal leading-tight mb-12 font-serif text-hyperlink text-center fade-in-element opacity-0"
    >
      Terms & Conditions
    </h1>

    <div class="max-w-[760px] mx-auto space-y-10 fade-in-element opacity-0">
      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Agreement to Terms
        </h2>
        <p class="text-lg font-light text-hyperlink">
          By accessing and using this website, you accept and agree to be bound
          by the terms and provisions of this agreement.
        </p>
      </div>

      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Services
        </h2>
        <p class="text-lg font-light text-hyperlink">
          Inscape Interiors provides interior design and architecture services.
          All services are subject to availability and individual project
          agreements.
        </p>
      </div>

      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Intellectual Property
        </h2>
        <p class="text-lg font-light text-hyperlink">
          All content on this website, including text, graphics, logos, images,
          and designs, is the property of Inscape Interiors and protected by
          copyright laws.
        </p>
      </div>

      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Use of Website
        </h2>
        <p class="text-lg font-light text-hyperlink">
          You may not use this website for any unlawful purpose or in any way
          that could damage, disable, or impair the website or its services.
        </p>
      </div>

      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Project Agreements
        </h2>
        <p class="text-lg font-light text-hyperlink">
          All design projects are subject to separate written agreements
          outlining scope, fees, timelines, and deliverables.
        </p>
      </div>

      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Limitation of Liability
        </h2>
        <p class="text-lg font-light text-hyperlink">
          Inscape Interiors shall not be liable for any indirect, incidental, or
          consequential damages arising from the use of our website or services.
        </p>
      </div>

      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Links to Third-Party Sites
        </h2>
        <p class="text-lg font-light text-hyperlink">
          Our website may contain links to third-party websites. We are not
          responsible for the content or practices of these external sites.
        </p>
      </div>

      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Changes to Terms
        </h2>
        <p class="text-lg font-light text-hyperlink">
          We reserve the right to modify these terms at any time. Changes will
          be effective immediately upon posting to this page.
        </p>
      </div>

      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Governing Law
        </h2>
        <p class="text-lg font-light text-hyperlink">
          These terms shall be governed by and construed in accordance with the
          applicable laws of India.
        </p>
      </div>

      <div>
        <h2
          class="text-2xl md:text-3xl font-normal font-serif text-hyperlink mb-4"
        >
          Contact
        </h2>
        <p class="text-lg font-light text-hyperlink">
          For questions regarding these terms, please contact us at <a
            href="mailto:dezinekraft.studio@gmail.com"
            class="underline hover:opacity-60 transition-opacity duration-300"
            >dezinekraft.studio@gmail.com</a
          >.
        </p>
      </div>
    </div>

    <p
      class="text-sm font-light text-hyperlink/60 text-center mt-16 fade-in-element opacity-0"
    >
      Last updated: February 2026
    </p>
  </section>
</Layout>

<style>
  .fade-in-element {
    transition:
      opacity 1.2s ease-out,
      transform 1.2s ease-out;
    transform: translateY(20px);
  }
  .fade-in-element.visible {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add("visible"), index * 200);
        }
      });
    },
    { threshold: 0.15 },
  );
  document
    .querySelectorAll(".fade-in-element")
    .forEach((el) => observer.observe(el));
</script>
