---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Craftsmanship — Inscape Interiors">
  <!-- HERO IMAGE -->
  <section class="w-full">
    <div class="w-full h-[80vh] overflow-hidden fade-in-element opacity-0">
      <img
        src="/images/craftsmanship/hero.webp"
        alt="Inscape Craftsmanship"
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <!-- INTRO -->
  <section class="w-full py-section">
    <div class="max-w-[760px] mx-auto text-center">
      <h1
        class="text-[48px] md:text-[56px] font-normal font-serif text-hyperlink leading-tight mb-8 fade-in-element opacity-0"
      >
        Craftsmanship
      </h1>
      <p class="text-lg font-light text-hyperlink fade-in-element opacity-0">
        At Inscape, craftsmanship is where vision becomes reality. Every line we
        draw, every material we source, and every detail we execute is guided by
        precision, discipline, and refined artistry.
      </p>
    </div>
  </section>

  <!-- ROW 1: Image left, Text right -->
  <section class="w-full py-section">
    <div class="flex flex-col md:flex-row gap-16 items-center">
      <div class="w-full md:w-[48%] fade-in-element opacity-0">
        <img
          src="/images/craftsmanship/craft-1.webp"
          alt="Inscape Craftsmanship"
          class="w-full h-auto"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div
        class="w-full md:w-[44%] flex flex-col justify-center py-8 space-y-6 fade-in-element opacity-0"
      >
        <h2
          class="text-[36px] font-normal font-serif text-hyperlink leading-tight"
        >
          Master Artisans
        </h2>
        <p class="text-lg font-light text-hyperlink">
          We collaborate with master artisans, skilled carpenters, fabricators,
          and finishing specialists who understand that luxury lies in the
          details.
        </p>
        <p class="text-lg font-light text-hyperlink">
          From bespoke joinery and flawless finishes to perfectly aligned
          architectural elements, our execution reflects uncompromising
          standards.
        </p>
      </div>
    </div>
  </section>

  <!-- ROW 2: Text left, Image right -->
  <section class="w-full py-section">
    <div class="flex flex-col md:flex-row gap-16 items-center">
      <div
        class="w-full md:w-[44%] flex flex-col justify-center py-8 space-y-6 fade-in-element opacity-0"
      >
        <h2
          class="text-[36px] font-normal font-serif text-hyperlink leading-tight"
        >
          Handcrafted Furniture & Joinery
        </h2>
        <p class="text-lg font-light text-hyperlink">
          Inscape designs and produces handcrafted furniture tailored to each
          project. We specialise in high-end wardrobes, bespoke kitchens, and
          custom-built joinery that combine elegance, durability, and superior
          craftsmanship.
        </p>
        <p class="text-lg font-light text-hyperlink">
          Every piece is thoughtfully designed and precisely constructed to
          complement the overall design concept.
        </p>
      </div>
      <div class="w-full md:w-[48%] fade-in-element opacity-0">
        <img
          src="/images/craftsmanship/craft-2.webp"
          alt="Handcrafted Furniture"
          class="w-full h-auto"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- ROW 3: Image left, Text right -->
  <section class="w-full py-section">
    <div class="flex flex-col md:flex-row gap-16 items-center">
      <div class="w-full md:w-[48%] fade-in-element opacity-0">
        <img
          src="/images/craftsmanship/craft-3.webp"
          alt="Inscape Precision"
          class="w-full h-auto"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div
        class="w-full md:w-[44%] flex flex-col justify-center py-8 space-y-6 fade-in-element opacity-0"
      >
        <h2
          class="text-[36px] font-normal font-serif text-hyperlink leading-tight"
        >
          Built to Endure
        </h2>
        <p class="text-lg font-light text-hyperlink">
          We believe true craftsmanship is not just about building — it is about
          creating spaces that endure, inspire, and elevate everyday living.
        </p>
        <p class="text-lg font-light text-hyperlink">
          Our integrated team of architects, project managers, and skilled
          craftsmen work collaboratively to maintain strict timelines while
          upholding the highest standards of quality and precision.
        </p>
        <div class="pt-4">
          <a
            href="/contact"
            class="inline-block border border-secondary bg-secondary text-primary rounded-full hover:bg-primary hover:text-secondary transition-colors duration-300 px-8 py-3 text-base"
          >
            Begin Your Bespoke Journey
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .fade-in-element {
    transition:
      opacity 1.2s ease-out,
      transform 1.2s ease-out;
    transform: translateY(20px);
  }
  .fade-in-element.visible {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add("visible"), index * 200);
        }
      });
    },
    { threshold: 0.15 },
  );
  document
    .querySelectorAll(".fade-in-element")
    .forEach((el) => observer.observe(el));
</script>
