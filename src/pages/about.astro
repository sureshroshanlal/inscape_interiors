---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About — Inscape Interiors">
  <!-- SECTION 1: Hero / Bio -->
  <section class="w-full py-section">
    <div class="flex flex-col md:flex-row gap-16 items-start">
      <!-- Left: Portrait image -->
      <div class="w-full md:w-[42%] fade-in-element opacity-0">
        <img
          src="/images/about/about-hero.jpg"
          alt="Inscape Interiors Studio"
          class="w-full h-auto"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- Right: Bio text -->
      <div
        class="w-full md:w-[58%] flex flex-col justify-center py-8 fade-in-element opacity-0"
      >
        <h1
          class="text-[48px] md:text-[56px] font-normal font-serif text-hyperlink leading-tight mb-8"
        >
          About Inscape
        </h1>
        <div class="space-y-6 text-lg font-light text-hyperlink">
          <p>
            At Inscape, design is intentional, immersive, and investment-driven.
          </p>
          <p>
            As a design-build firm, we integrate spatial planning excellence,
            sustainable architecture, and ultra-luxury interiors into a seamless
            execution model. From minimalist luxury homes to Indian colonial
            farmhouses, every project reflects our signature design language —
            defined by timeless elegance and modern sophistication.
          </p>
          <p>
            With over 20 years of committed experience, our expertise spans
            bespoke interiors, contemporary and tropical architecture, luxury
            surface solutions, smart home integration, and highly functional
            sustainable design.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: The Style -->
  <section class="w-full py-section">
    <!-- Heading -->
    <h2
      class="text-[48px] md:text-[56px] font-normal font-serif text-hyperlink leading-tight mb-16 fade-in-element opacity-0"
    >
      The Style
    </h2>

    <!-- Row 1: Text left, Image right -->
    <div class="flex flex-col md:flex-row gap-16 items-start mb-20">
      <div
        class="w-full md:w-[40%] space-y-6 text-lg font-light text-hyperlink fade-in-element opacity-0"
      >
        <p>Sourcing at Inscape is a curated process — not procurement.</p>
        <p>
          Through our premium vendor network and artisan collaborations, we
          handpick imported marble, designer finishes, handcrafted furniture,
          and custom lighting solutions to align with each project's
          architectural narrative.
        </p>
        <p>
          Every element is selected with precision to ensure elevated spaces
          that stand the test of time.
        </p>
      </div>
      <div class="w-full md:w-[55%] fade-in-element opacity-0">
        <div class="relative">
          <img
            src="/images/about/style-1.jpg"
            alt="Inscape Interiors Style"
            class="w-full h-auto"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>

    <!-- Row 2: Image left, Text right -->
    <div class="flex flex-col md:flex-row gap-16 items-start">
      <div class="w-full md:w-[45%] fade-in-element opacity-0">
        <img
          src="/images/about/style-2.jpg"
          alt="Inscape Interiors Style"
          class="w-full h-auto"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div
        class="w-full md:w-[50%] space-y-6 text-lg font-light text-hyperlink fade-in-element opacity-0 md:pt-8"
      >
        <p>
          Our turnkey execution model ensures end-to-end project management,
          seamless design and execution integration, and quality-controlled site
          supervision.
        </p>
        <p>
          We specialise in high-value real estate design solutions —
          transforming vision into landmark residences, from concept to
          completion.
        </p>
        <p>
          Designing future-ready homes for discerning clients. Every space we
          create is a reflection of how you live — elevated.
        </p>
        <div class="pt-4">
          <a
            href="/contact"
            class="inline-block border border-secondary bg-secondary text-primary rounded-full hover:bg-primary hover:text-secondary transition-colors duration-300 px-8 py-3 text-base tracking-wide"
          >
            Begin Your Bespoke Journey
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .fade-in-element {
    transition:
      opacity 1.2s ease-out,
      transform 1.2s ease-out;
    transform: translateY(20px);
  }

  .fade-in-element.visible {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add("visible");
          }, index * 200);
        }
      });
    },
    { threshold: 0.15 },
  );

  document.querySelectorAll(".fade-in-element").forEach((el) => {
    observer.observe(el);
  });
</script>
