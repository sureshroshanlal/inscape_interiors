---

<section class="w-full py-section">
  <div class="flex flex-col md:flex-row items-start gap-16">
    <!-- LEFT: TEXT -->
    <div class="w-full md:w-1/2">
      <!-- Sunburst placeholder — client to replace with actual image -->
      <img
        src="/images/interiors-sunburst.png"
        alt=""
        class="w-16 mb-6 fade-in-element opacity-0"
        aria-hidden="true"
      />

      <h3 class="text-[35px] font-normal mb-8 fade-in-element opacity-0">
        Interiors
      </h3>

      <div class="space-y-6 text-base font-light fade-in-element opacity-0">
        <p>
          Our services range from colour consultancy and space planning to
          full-home architectural and interior design.
        </p>
        <p>
          We develop strong relationships with clients to understand their
          needs, creating spaces that ease and enhance their daily lives.
        </p>
      </div>

      <a
        href="/projects"
        class="inline-block mt-10 border border-secondary bg-secondary text-primary rounded-full hover:bg-primary hover:text-secondary transition-colors duration-300 px-8 py-3 text-base tracking-wide fade-in-element opacity-0"
      >
        View Projects
      </a>
    </div>

    <!-- RIGHT: IMAGE -->
    <div class="w-full md:w-1/2 fade-in-element opacity-0">
      <img
        src="/images/interiors-side.jpg"
        alt="Inscape Interiors"
        class="w-full h-auto"
      />
    </div>
  </div>

  <!-- Wide image below — same global padding applies -->
  <div class="w-full mt-16">
    <img
      src="/images/interiors-wide.jpg"
      alt="Inscape Interiors"
      class="w-full h-auto fade-in-element opacity-0"
    />
  </div>
</section>

<style>
  .fade-in-element {
    transition:
      opacity 0.8s ease-out,
      transform 0.8s ease-out;
    transform: translateY(20px);
  }

  .fade-in-element.visible {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add("visible");
          }, index * 200);
        }
      });
    },
    { threshold: 0.15 },
  );

  document.querySelectorAll(".fade-in-element").forEach((el) => {
    observer.observe(el);
  });
</script>
