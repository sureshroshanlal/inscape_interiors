<section class="w-full py-section">
  <div class="flex flex-col md:flex-row gap-8 items-start">
    <!-- LEFT IMAGE — taller, fixed height, label bottom-left white -->
    <div
      class="w-full md:w-[45%] fade-in-element opacity-0"
      data-parallax="left"
    >
      <a href="/projects/golbourne-road" class="relative block img-hover-zoom">
        <div class="w-full h-[70vh] overflow-hidden">
          <img
            src="/images/projects/golbourne-road.jpg"
            alt="Golborne Road Interior"
            class="w-full h-full object-cover"
            decoding="async"
          />
        </div>
        <span
          class="absolute bottom-6 left-6 text-white font-serif italic text-xl leading-tight drop-shadow-lg"
        >
          artist apartment<br />golbourne rd
        </span>
      </a>
    </div>

    <!-- RIGHT IMAGE — shorter, offset down significantly, label top-left dark brown -->
    <div
      class="w-full md:w-[45%] md:mt-40 fade-in-element opacity-0"
      data-parallax="right"
    >
      <a href="/projects/elgin-crescent" class="relative block img-hover-zoom">
        <div class="w-full h-[50vh] overflow-hidden">
          <img
            src="/images/projects/elgin-crescent.jpg"
            alt="Elgin Crescent Interior"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        <span
          class="absolute top-6 left-6 text-secondary font-serif italic text-xl leading-tight drop-shadow-sm"
        >
          holland park<br />family home
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .fade-in-element {
    transition:
      opacity 1.2s ease-out,
      transform 1.2s ease-out;
    transform: translateY(20px);
  }

  .fade-in-element.visible {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const leftEl = document.querySelector<HTMLElement>('[data-parallax="left"]');
  const rightEl = document.querySelector<HTMLElement>(
    '[data-parallax="right"]',
  );
  const section = leftEl?.closest("section") as HTMLElement | null;

  function parallax() {
    if (!leftEl || !rightEl || !section) return;

    const sectionTop = section.getBoundingClientRect().top + window.scrollY;
    const relativeScroll = window.scrollY - sectionTop + window.innerHeight;
    const offset = relativeScroll * 0.05;

    // scroll down: left moves DOWN (+), right moves UP (-)
    leftEl.style.transform = `translateY(${offset}px)`;
    rightEl.style.transform = `translateY(${-offset}px)`;
  }

  window.addEventListener("scroll", parallax, { passive: true });
  parallax();

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add("visible");
          }, index * 200);
        }
      });
    },
    { threshold: 0.15 },
  );

  document.querySelectorAll(".fade-in-element").forEach((el) => {
    observer.observe(el);
  });
</script>
