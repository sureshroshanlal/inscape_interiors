---

---

<footer class="bg-secondary py-16">
  <!-- Emblem — centered, full width, above links on mobile -->
  <div class="flex justify-center mb-12">
    <a
      href="/"
      class="inline-block hover:opacity-80 transition-opacity duration-300"
    >
      <img
        src="/images/footer_emblem-1.webp"
        alt="Inscape Interiors"
        class="h-24 md:h-28 w-auto"
      />
    </a>
  </div>

  <!-- Nav links grid -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 mb-12">
    <!-- Col 1 -->
    <div class="flex flex-col gap-4 items-center">
      <a
        href="/projects"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Projects</a
      >
      <a
        href="/about"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >About</a
      >
    </div>

    <!-- Col 2 -->
    <div class="flex flex-col gap-4 items-center">
      <a
        href="/craftsmanship"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Craftsmanship</a
      >
      <a
        href="/sourcing"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Sourcing</a
      >
    </div>

    <!-- Col 3 -->
    <div class="flex flex-col gap-4 items-center">
      <a
        href="https://www.instagram.com/inscape.interiors/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Instagram</a
      >
      <a
        href="/contact"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Contact</a
      >
    </div>

    <!-- Col 4 -->
    <div class="flex flex-col gap-4 items-center">
      <a
        href="/terms"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Terms</a
      >
      <a
        href="/privacy-policy"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Privacy Policy</a
      >
    </div>
  </div>

  <!-- Copyright -->
  <div class="text-center">
    <p class="text-sm font-serif text-primary/50">
      Copyright © Inscape Interiors. All rights reserved.
    </p>
  </div>
</footer>
