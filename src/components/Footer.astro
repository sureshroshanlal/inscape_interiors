---

---

<footer class="bg-secondary py-16">
  <!-- MOBILE: emblem centered above 2-col grid -->
  <div class="md:hidden">
    <div class="flex justify-center mb-12">
      <a
        href="/"
        class="inline-block hover:opacity-80 transition-opacity duration-300"
      >
        <img
          src="/images/footer_emblem-1.webp"
          alt="Inscape Interiors"
          class="h-24 w-auto"
        />
      </a>
    </div>
    <div class="grid grid-cols-2 gap-6 mb-12">
      <div class="flex flex-col gap-4 items-center">
        <a
          href="/projects"
          class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
          >Projects</a
        >
        <a
          href="/about"
          class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
          >About</a
        >
      </div>
      <div class="flex flex-col gap-4 items-center">
        <a
          href="/craftsmanship"
          class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
          >Craftsmanship</a
        >
        <a
          href="/sourcing"
          class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
          >Sourcing</a
        >
      </div>
      <div class="flex flex-col gap-4 items-center">
        <a
          href="https://www.instagram.com/inscape.interiors/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
          >Instagram</a
        >
        <a
          href="/contact"
          class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
          >Contact</a
        >
      </div>
      <div class="flex flex-col gap-4 items-center">
        <a
          href="/terms"
          class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
          >Terms</a
        >
        <a
          href="/privacy-policy"
          class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
          >Privacy Policy</a
        >
      </div>
    </div>
  </div>

  <!-- DESKTOP: 5-col grid, emblem in center col -->
  <div class="hidden md:grid grid-cols-5 gap-8 items-center mb-16">
    <!-- Col 1 -->
    <div class="flex flex-col gap-4 items-center">
      <a
        href="/projects"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Projects</a
      >
      <a
        href="/about"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >About</a
      >
    </div>
    <!-- Col 2 -->
    <div class="flex flex-col gap-4 items-center">
      <a
        href="/craftsmanship"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Craftsmanship</a
      >
      <a
        href="/sourcing"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Sourcing</a
      >
    </div>
    <!-- Col 3: Emblem -->
    <div class="flex justify-center items-center">
      <a
        href="/"
        class="inline-block hover:opacity-80 transition-opacity duration-300"
      >
        <img
          src="/images/footer_emblem-1.webp"
          alt="Inscape Interiors"
          class="h-28 w-auto"
        />
      </a>
    </div>
    <!-- Col 4 -->
    <div class="flex flex-col gap-4 items-center">
      <a
        href="https://www.instagram.com/inscape.interiors/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Instagram</a
      >
      <a
        href="/contact"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Contact</a
      >
    </div>
    <!-- Col 5 -->
    <div class="flex flex-col gap-4 items-center">
      <a
        href="/terms"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Terms</a
      >
      <a
        href="/privacy-policy"
        class="text-[16px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Privacy Policy</a
      >
    </div>
  </div>

  <!-- Copyright -->
  <div class="text-center">
    <p class="text-sm font-serif text-primary/50">
      Copyright © Inscape Interiors. All rights reserved.
    </p>
  </div>
</footer>
