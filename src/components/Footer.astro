---

---

<footer class="bg-secondary py-12 md:py-14">
  <div class="page-padding">
    <!-- Footer Grid -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-12 lg:gap-16 mb-8">
      <!-- Column 1 - Navigation -->
      <div>
        <nav>
          <ul class="flex flex-col gap-4 md:gap-5 items-start md:items-center">
            <li>
              <a
                href="/projects"
                class="text-[11px] tracking-widest uppercase text-primary transition-opacity duration-300 hover:opacity-60"
              >
                Projects
              </a>
            </li>
            <li>
              <a
                href="/about"
                class="text-[11px] tracking-widest uppercase text-primary transition-opacity duration-300 hover:opacity-60"
              >
                About
              </a>
            </li>
          </ul>
        </nav>
      </div>

      <!-- Column 2 - Contact -->
      <div>
        <nav>
          <ul class="flex flex-col gap-4 md:gap-5 items-start md:items-center">
            <li>
              <a
                href="/contact"
                class="text-[11px] tracking-widest uppercase text-primary transition-opacity duration-300 hover:opacity-60"
              >
                Contact
              </a>
            </li>
          </ul>
        </nav>
      </div>

      <!-- Column 3 - Emblem (centered) -->
      <div
        class="col-span-2 md:col-span-1 flex justify-center items-center order-first md:order-none"
      >
        <a
          href="/"
          class="inline-block opacity-90 hover:opacity-100 transition-opacity duration-300"
        >
          <img
            src="/images/footer-emblem.svg"
            alt="Inscape Interiors"
            class="h-24 md:h-28 w-auto"
          />
        </a>
      </div>

      <!-- Column 4 - Social -->
      <div>
        <nav>
          <ul class="flex flex-col gap-4 md:gap-5 items-start md:items-center">
            <li>
              <a
                href="https://www.instagram.com/inscape.interiors/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-[11px] tracking-widest uppercase text-primary transition-opacity duration-300 hover:opacity-60"
              >
                Instagram
              </a>
            </li>
            <li>
              <a
                href="https://www.pinterest.com/inscapeinteriors/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-[11px] tracking-widest uppercase text-primary transition-opacity duration-300 hover:opacity-60"
              >
                Pinterest
              </a>
            </li>
          </ul>
        </nav>
      </div>

      <!-- Column 5 - Legal -->
      <div>
        <nav>
          <ul class="flex flex-col gap-4 md:gap-5 items-start md:items-center">
            <li>
              <a
                href="/terms"
                class="text-[11px] tracking-widest uppercase text-primary transition-opacity duration-300 hover:opacity-60"
              >
                Terms
              </a>
            </li>
            <li>
              <a
                href="/privacy-policy"
                class="text-[11px] tracking-widest uppercase text-primary transition-opacity duration-300 hover:opacity-60"
              >
                Privacy Policy
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>

    <!-- Copyright -->
    <div class="text-center pt-6 border-t border-primary/20">
      <p class="text-[10px] tracking-widest uppercase text-primary/60">
        Copyright © Inscape Interiors. All rights reserved.
      </p>
    </div>
  </div>
</footer>
