---

---

<footer class="bg-secondary py-16">
  <div class="grid grid-cols-2 md:grid-cols-5 gap-8 items-center mb-16">
    <!-- Col 1: Projects, About -->
    <div class="flex flex-col gap-4 items-start md:items-center">
      <a
        href="/projects"
        class=".text-[18px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Projects</a
      >
      <a
        href="/about"
        class=".text-[18px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >About</a
      >
    </div>

    <!-- Col 2: Contact -->
    <div class="flex flex-col gap-4 items-start md:items-center">
      <a
        href="/craftsmanship"
        class=".text-[18px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Craftsmanship</a
      >
      <a
        href="/sourcing"
        class=".text-[18px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Sourcing</a
      >
    </div>

    <!-- Col 3: Emblem -->
    <div
      class="col-span-2 md:col-span-1 flex justify-center items-center order-first md:order-none"
    >
      <a
        href="/"
        class="inline-block hover:opacity-80 transition-opacity duration-300"
      >
        <img
          src="/images/footer_emblem-1.webp"
          alt="Inscape Interiors"
          class="h-24 md:h-28 w-auto"
        />
      </a>
    </div>

    <!-- Col 4: Social -->
    <div class="flex flex-col gap-4 items-start md:items-center">
      <a
        href="https://www.instagram.com/inscape.interiors/"
        target="_blank"
        rel="noopener noreferrer"
        class=".text-[18px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Instagram</a
      >
      <a
        href="/contact"
        class=".text-[18px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Contact</a
      >
    </div>

    <!-- Col 5: Legal -->
    <div class="flex flex-col gap-4 items-start md:items-center">
      <a
        href="/terms"
        class=".text-[18px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Terms</a
      >
      <a
        href="/privacy-policy"
        class=".text-[18px] font-serif text-primary hover:opacity-60 transition-opacity duration-300"
        >Privacy Policy</a
      >
    </div>
  </div>

  <!-- Copyright -->
  <div class="text-center">
    <p class="text-sm font-serif text-primary/50">
      Copyright © Inscape Interiors. All rights reserved.
    </p>
  </div>
</footer>
