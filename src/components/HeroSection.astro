---

<section class="w-full">
  <!-- Hero image — natural aspect ratio, no forced height, no stretch -->
  <div class="w-full overflow-hidden">
    <img
      src="/images/hero-banner.webp"
      alt="Inscape Interiors"
      class="w-full h-auto block fade-in-element opacity-0"
      loading="eager"
      decoding="async"
    />
  </div>

  <!-- Intro text -->
  <div class="py-12 md:py-section text-center">
    <h1
      class="text-[38px] md:text-[52px] font-normal leading-tight mb-6 font-serif text-hyperlink max-w-[700px] mx-auto fade-in-element opacity-0"
    >
      Designing Spaces With Precision, Craftsmanship & Purpose
    </h1>
    <p
      class="text-base max-w-[480px] mx-auto text-hyperlink fade-in-element opacity-0"
    >
      Transforming interiors through architecture, handcrafted detail, and
      global sourcing.
    </p>
  </div>
</section>

<style>
  .fade-in-element {
    transition:
      opacity 0.8s ease-out,
      transform 0.8s ease-out;
    transform: translateY(20px);
  }
  .fade-in-element.visible {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add("visible");
          }, index * 200);
        }
      });
    },
    { threshold: 0 },
  );
  document
    .querySelectorAll(".fade-in-element")
    .forEach((el) => observer.observe(el));
</script>
