---

---

<section class="w-full">
  <!-- Hero image -->
  <div class="w-full h-[40vh] md:h-[80vh] overflow-hidden">
    <img
      src="/images/hero-banner.jpg"
      alt="Inscape Interiors"
      class="w-full h-full object-cover fade-in-element opacity-0"
      loading="eager"
    />
  </div>

  <!-- Intro text -->
  <div class="py-section text-center">
    <h1
      class="text-[38px] md:text-[52px] font-normal leading-tight mb-8 font-serif text-hyperlink fade-in-element opacity-0 max-w-[700px] mx-auto"
    >
      Designing Spaces With Precision, Craftsmanship & Purpose
    </h1>
    <p
      class="text-base max-w-[480px] mx-auto text-hyperlink fade-in-element opacity-0"
    >
      Transforming interiors through architecture, handcrafted detail, and
      global sourcing.
    </p>
  </div>
</section>

<style>
  .fade-in-element {
    transition:
      opacity 0.8s ease-out,
      transform 0.8s ease-out;
    transform: translateY(20px);
  }

  .fade-in-element.visible {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add("visible");
          }, index * 200);
        }
      });
    },
    { threshold: 0 },
  );

  document.querySelectorAll(".fade-in-element").forEach((el) => {
    observer.observe(el);
  });
</script>
