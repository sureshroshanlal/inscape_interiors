---
const INSTAGRAM_PROFILE = "https://www.instagram.com/inscape.interiors/";

// Replace POST_ID_X with actual Instagram post IDs from each post URL
const images = [
  {
    src: "/images/instagram/post-1.jpg",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_1/",
  },
  {
    src: "/images/instagram/post-2.jpg",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_2/",
  },
  {
    src: "/images/instagram/post-3.jpg",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_3/",
  },
  {
    src: "/images/instagram/post-4.jpg",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_4/",
  },
  {
    src: "/images/instagram/post-5.jpg",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_5/",
  },
  {
    src: "/images/instagram/post-6.jpg",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_6/",
  },
];
---

<section class="w-full py-section">
  <!-- Heading links to profile -->
  <div class="flex items-center justify-center gap-2 mb-8">
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-secondary"
      aria-hidden="true"
    >
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
      <circle cx="12" cy="12" r="4"></circle>
      <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"
      ></circle>
    </svg>
    <a
      href={INSTAGRAM_PROFILE}
      target="_blank"
      rel="noopener noreferrer"
      class="text-base font-serif text-secondary"
    >
      Follow
    </a>
  </div>

  <!-- 6 square images — each links to its own post -->
  <div class="w-full grid grid-cols-6 gap-1">
    {
      images.map((image) => (
        <a
          href={image.url}
          target="_blank"
          rel="noopener noreferrer"
          class="relative block aspect-square overflow-hidden group"
          aria-label="View post on Instagram"
        >
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-20 transition-opacity duration-500 ease-out pointer-events-none" />
        </a>
      ))
    }
  </div>
</section>
