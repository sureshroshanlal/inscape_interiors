---
const INSTAGRAM_PROFILE = "https://www.instagram.com/inscape.interiors/";

const images = [
  {
    src: "/images/instagram/post-1.webp",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_1/",
  },
  {
    src: "/images/instagram/post-2.webp",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_2/",
  },
  {
    src: "/images/instagram/post-3.webp",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_3/",
  },
  {
    src: "/images/instagram/post-4.webp",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_4/",
  },
  {
    src: "/images/instagram/post-5.webp",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_5/",
  },
  {
    src: "/images/instagram/post-6.webp",
    alt: "Inscape Interiors on Instagram",
    url: "https://www.instagram.com/p/POST_ID_6/",
  },
];
---

<section class="w-full py-section">
  <!-- Heading -->
  <div class="flex flex-col items-center justify-center gap-2 mb-8">
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-secondary"
      aria-hidden="true"
    >
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
      <circle cx="12" cy="12" r="4"></circle>
      <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"
      ></circle>
    </svg>
    <a
      href={INSTAGRAM_PROFILE}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xl font-serif text-secondary"
    >
      Follow
    </a>
  </div>

  <!-- Mobile: horizontal scroll, 2 images visible at a time -->
  <!-- Desktop: 6 col grid -->
  <div
    class="md:hidden flex overflow-x-auto snap-x snap-mandatory gap-2 scrollbar-hide"
  >
    {
      images.map((image) => (
        <a
          href={image.url}
          target="_blank"
          rel="noopener noreferrer"
          class="relative flex-none w-[48%] aspect-square overflow-hidden group snap-start"
          aria-label="View post on Instagram"
        >
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-20 transition-opacity duration-500 ease-out pointer-events-none" />
        </a>
      ))
    }
  </div>

  <!-- Desktop grid -->
  <div class="hidden md:grid grid-cols-6 gap-2">
    {
      images.map((image) => (
        <a
          href={image.url}
          target="_blank"
          rel="noopener noreferrer"
          class="relative block aspect-square overflow-hidden group"
          aria-label="View post on Instagram"
        >
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-20 transition-opacity duration-500 ease-out pointer-events-none" />
        </a>
      ))
    }
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
